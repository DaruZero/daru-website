{
  "name": "danelon.me",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "author": {
    "name": "Matteo Danelon",
    "url": "https://danelon.me",
    "email": "matteo@danelon.me"
  },
  "bugs": {
    "url": "https://github.com/DaruZero/daru-website/issues"
  },
  "homepage": "https://github.com/DaruZero/daru-website",
  "keywords": [
    "terminal",
    "website",
    "landing page",
    "danelon"
  ],
  "scripts": {
    "build": "npm run build:css && npm run build:remix",
    "build:remix": "cross-env NODE_ENV=production remix build",
    "build:css": "tailwindcss -o ./app/styles/tailwind.css",
    "start": "cross-env NODE_ENV=production node ./build/index.js",
    "dev": "concurrently -p \"[{name}]\" -n \"tailwind,remix\" -c \"yellow.bold,red.bold\" \"npm:dev:css\" \"npm:dev:remix\"",
    "dev:remix": "cross-env NODE_ENV=development remix dev",
    "dev:css": "tailwindcss -o ./app/styles/tailwind.css --watch",
    "dev:docker": "docker compose up -d",
    "dev:docker:stop": "docker compose down",
    "format": "prettier --write .",
    "db:push": "prisma db push",
    "db:generate": "prisma generate && prisma migrate"
  },
  "dependencies": {
    "@remix-run/node": "^1.5.1",
    "@remix-run/react": "^1.5.1",
    "@remix-run/serve": "^1.5.1",
    "cross-env": "^7.0.3",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@remix-run/dev": "^1.5.1",
    "@remix-run/eslint-config": "^1.5.1",
    "@types/react": "^17.0.45",
    "@types/react-dom": "^17.0.17",
    "autoprefixer": "^10.4.7",
    "concurrently": "^7.2.1",
    "eslint": "^8.15.0",
    "postcss": "^8.4.14",
    "prettier": "^2.6.2",
    "prettier-plugin-tailwind": "^2.2.12",
    "tailwindcss": "^3.0.24",
    "typescript": "^4.6.4"
  },
  "engines": {
    "node": ">=14"
  }
}
